.liquor-cards {
  padding: 60px 10%;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 30px;
  max-width: 100%;
}

/* Individual Card */
.card {
  background: #ffffff;
  border-radius: 20px;
  padding: 20px;
  text-align: center;
  cursor: pointer;
  border: 1px solid #bbdefb;
  box-shadow: 0 4px 16px rgba(21, 101, 192, 0.1);
  transition:
    transform 0.3s ease,
    box-shadow 0.3s ease,
    border-color 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}
.card:hover {
  transform: translateY(-10px);
  box-shadow: 0 16px 40px rgba(21, 101, 192, 0.2);
  border-color: #1565c0;
}

.card img {
  width: 100%;
  height: 220px;
  object-fit: contain;
  border-radius: 15px;
  background: white;
}
.card h2 {
  margin-top: 14px;
  font-size: 20px;
  font-weight: 800;
  color: #111111;
  line-height: 1.3;
  flex-grow: 1;
}
